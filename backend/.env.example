# 后端应用基础配置
APP_NAME=CompDDL API
API_V1_STR=/api

# 当前已在 config.py 中出现的数据库配置
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=compddl

# Ark-only Agents SDK 运行配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_DEFAULT_MODEL=deepseek-v3-2-251201
RESEARCH_RUNTIME_MODE=agents_sdk
RESEARCH_RUNTIME_TRACING_ENABLED=0
RESEARCH_RUNTIME_SESSION_DB=
RESEARCH_RUNTIME_STRICT_MODE=0
