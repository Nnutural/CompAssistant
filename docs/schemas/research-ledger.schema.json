{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compassistant.local/schemas/research-ledger.schema.json",
  "title": "ResearchLedger",
  "description": "科研多智能体运行时中的 Research Ledger 契约，用于记录任务、来源、证据与综合结论。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "ledger_id",
    "session_id",
    "topic",
    "research_question",
    "status",
    "scope",
    "task_history",
    "source_registry",
    "evidence_log",
    "created_at"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0",
      "description": "契约版本号。"
    },
    "ledger_id": {
      "type": "string",
      "minLength": 1,
      "description": "Ledger 唯一标识。"
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "description": "关联研究会话标识。"
    },
    "topic": {
      "type": "string",
      "minLength": 1,
      "description": "研究主题。"
    },
    "research_question": {
      "type": "string",
      "minLength": 1,
      "description": "核心研究问题。"
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "completed", "archived"],
      "description": "Ledger 当前状态。"
    },
    "owner": {
      "type": "string",
      "description": "Ledger 的逻辑负责人，可为用户、系统或智能体名称。"
    },
    "run_id": {
      "type": "string",
      "description": "当前或最近一次运行的唯一标识。"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "competition_recommendation",
        "competition_eligibility_check",
        "competition_timeline_plan",
        "research_plan",
        "source_discovery",
        "evidence_extraction",
        "synthesis",
        "review",
        "report_draft",
        "schema_validation",
        "general"
      ],
      "description": "当前或最近一次运行的任务类型。"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "received",
        "planning",
        "retrieving_local_context",
        "reasoning",
        "validating_output",
        "persisting_artifacts",
        "completed",
        "failed",
        "awaiting_review"
      ],
      "description": "当前运行状态。"
    },
    "completed_states": {
      "type": "array",
      "description": "当前运行已完成的状态列表。",
      "items": {
        "$ref": "#/$defs/runState"
      },
      "default": []
    },
    "error_stage": {
      "$ref": "#/$defs/runState"
    },
    "scope": {
      "$ref": "#/$defs/researchScope"
    },
    "hypotheses": {
      "type": "array",
      "description": "当前阶段提出的研究假设。",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "task_history": {
      "type": "array",
      "description": "围绕本主题执行过的任务轨迹。",
      "items": {
        "$ref": "#/$defs/ledgerTaskEntry"
      }
    },
    "source_registry": {
      "type": "array",
      "description": "当前纳入追踪的来源列表。",
      "items": {
        "$ref": "#/$defs/sourceRecord"
      }
    },
    "evidence_log": {
      "type": "array",
      "description": "从来源中抽取并沉淀的证据记录。",
      "items": {
        "$ref": "#/$defs/evidenceRecord"
      }
    },
    "events": {
      "type": "array",
      "description": "运行过程中记录的阶段事件。",
      "items": {
        "$ref": "#/$defs/runEvent"
      },
      "default": []
    },
    "raw_outputs": {
      "type": "object",
      "description": "各阶段保留的原始输出。",
      "additionalProperties": true,
      "default": {}
    },
    "repaired_outputs": {
      "type": "object",
      "description": "各阶段修复或提取后的输出。",
      "additionalProperties": true,
      "default": {}
    },
    "validation_errors": {
      "type": "array",
      "description": "输出验证阶段产生的错误或警告。",
      "items": {
        "$ref": "#/$defs/validationIssue"
      },
      "default": []
    },
    "parse_errors": {
      "type": "array",
      "description": "输出提取或修复阶段产生的解析错误。",
      "items": {
        "$ref": "#/$defs/validationIssue"
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "description": "面向运行时消费的结构化产物。",
      "items": {
        "$ref": "#/$defs/runtimeArtifact"
      },
      "default": []
    },
    "synthesis_notes": {
      "type": "array",
      "description": "阶段性综合结论或总结笔记。",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "final_artifacts": {
      "type": "array",
      "description": "最终产出的工件引用。",
      "items": {
        "$ref": "#/$defs/artifactItem"
      },
      "default": []
    },
    "open_questions": {
      "type": "array",
      "description": "尚未解决的问题列表。",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "model": {
      "type": "string",
      "description": "当前运行使用的模型名。"
    },
    "base_url": {
      "type": "string",
      "description": "当前运行使用的 Ark 兼容 base URL。"
    },
    "used_mock_fallback": {
      "type": "boolean",
      "description": "本次运行是否使用了 mock fallback。",
      "default": false
    },
    "fallback_reason": {
      "type": "string",
      "description": "本次运行触发 fallback 的原因。"
    },
    "elapsed_ms": {
      "type": "number",
      "description": "本次运行累计耗时，单位毫秒。"
    },
    "result_status": {
      "type": "string",
      "enum": ["draft", "completed", "blocked", "needs_human"],
      "description": "最近一次运行产物对应的结果状态。"
    },
    "result_summary": {
      "type": "string",
      "description": "最近一次运行结果摘要。"
    },
    "follow_up_items": {
      "type": "array",
      "description": "最近一次运行建议的后续事项。",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "blockers": {
      "type": "array",
      "description": "最近一次运行记录的阻塞项。",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "finding_count": {
      "type": "integer",
      "description": "最近一次运行结果中的 finding 数量。",
      "default": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Ledger 创建时间。"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Ledger 最近更新时间。"
    }
  },
  "$defs": {
    "runState": {
      "type": "string",
      "enum": [
        "received",
        "planning",
        "retrieving_local_context",
        "reasoning",
        "validating_output",
        "persisting_artifacts",
        "completed",
        "failed",
        "awaiting_review"
      ]
    },
    "researchScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "included_topics": {
          "type": "array",
          "description": "纳入研究范围的主题。",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "excluded_topics": {
          "type": "array",
          "description": "明确排除的主题。",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "success_criteria": {
          "type": "array",
          "description": "判定本轮研究完成的标准。",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "ledgerTaskEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "agent", "status"],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "description": "任务标识。"
        },
        "agent": {
          "type": "string",
          "minLength": 1,
          "description": "执行该任务的智能体名称。"
        },
        "status": {
          "type": "string",
          "enum": ["queued", "running", "completed", "blocked", "cancelled"],
          "description": "任务阶段状态。"
        },
        "summary": {
          "type": "string",
          "description": "任务阶段摘要。"
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "任务开始时间。"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time",
          "description": "任务结束时间。"
        }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "title", "locator"],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1,
          "description": "来源标识。"
        },
        "source_type": {
          "type": "string",
          "enum": ["doc", "paper", "web", "dataset", "interview", "note", "code"],
          "description": "来源类别。"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "来源标题。"
        },
        "locator": {
          "type": "string",
          "minLength": 1,
          "description": "来源定位信息，可为路径、URL 或其他引用。"
        },
        "credibility": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "对来源可信度的评估。"
        },
        "captured_by": {
          "type": "string",
          "description": "记录该来源的智能体名称。"
        },
        "tags": {
          "type": "array",
          "description": "来源标签。",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "source_id", "claim", "excerpt", "captured_by"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1,
          "description": "证据标识。"
        },
        "source_id": {
          "type": "string",
          "minLength": 1,
          "description": "证据来源标识。"
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "description": "证据支持的结论或事实表述。"
        },
        "excerpt": {
          "type": "string",
          "minLength": 1,
          "description": "摘录内容。"
        },
        "captured_by": {
          "type": "string",
          "minLength": 1,
          "description": "提取该证据的智能体名称。"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "description": "证据提取时间。"
        },
        "related_task_id": {
          "type": "string",
          "description": "若有，可关联触发该证据的任务标识。"
        }
      }
    },
    "runEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "state", "status", "message", "created_at"],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "$ref": "#/$defs/runState"
        },
        "status": {
          "type": "string",
          "enum": ["entered", "completed", "error", "warning", "fallback", "info"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string"
        },
        "detail": {
          "type": "object",
          "additionalProperties": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "validationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "kind", "message"],
      "properties": {
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["parse_error", "validation_error", "repair_warning", "runtime_error"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "runtimeArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "title", "payload"],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "payload": {},
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "artifactItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["file", "doc", "schema", "report", "note", "dataset", "ledger_entry"],
          "description": "产物类别。"
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "产物路径、URL 或逻辑标识。"
        },
        "title": {
          "type": "string",
          "description": "产物标题。"
        }
      }
    }
  }
}
