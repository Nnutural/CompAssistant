.gitignore

# OS / filesystem
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
Icon?
ehthumbs.db

# Editor / IDE
.vscode/
.idea/
*.iml
*.suo
*.user
*.userosscache
*.sln.docstates
*.code-workspace
.history/
.fleet/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Node / frontend
node_modules/
dist/
build/
coverage/
.nyc_output/
.cache/
.vite/
.eslintcache
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg
*.manifest
*.spec
.pyre/

# Virtual environments
.venv/
venv/
env/
ENV/
.conda/

# Jupyter
.ipynb_checkpoints/

# Environment files (keep examples)
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Temporary / backup files
*~
*.swp
*.swo
*.tmp
*.bak
*.orig
*.old

# Local databases / secrets
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.sqlite3-shm
*.sqlite3-wal
*.db
*.pem
*.key
*.p12

